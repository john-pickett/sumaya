{
  "name": "meditation",
  "version": "1.1.10",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "bump": "node bump-version.js && npm run commit:version",
    "bump:minor": "node bump-version.js minor && npm run commit:version",
    "bump:major": "node bump-version.js major && npm run commit:version",
    "build:ios": "npm run bump && eas build --platform ios --local",
    "build:android": "eas build --platform android --local",
    "commit:version": "git add package.json app.json && git commit -m \"chore: bump to $(node -p \"require('./package.json').version\")\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-haptics": "~15.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
